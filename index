   LOGOUT / BOOT
   ============================================================ */
$("#logoutBtn") && ($("#logoutBtn").onclick = ()=>{
  localStorage.removeItem("guerra_username");
  state = { username:null, me:null, myBuildings:[], allPlayers:[], allBattles:[], activeTab:"territorio" };
  showScreen("screen-login");
});

$("#loginBtn").onclick = doLogin;
$("#ob-submit").onclick = submitOnboarding;

renderUserPick();

// tenta retomar sessão salva
(async function boot(){
  if (!sb) return; // sem config ainda, fica na tela de login com aviso ao tentar entrar
  const saved = localStorage.getItem("guerra_username");
  if (saved && USERS.includes(saved)){
    const { data } = await sb.from("players").select("*").eq("username", saved).maybeSingle();
    if (data){
      state.username = saved;
      state.me = data;
      selectedUser = saved;
      if (!data.onboarded){ showScreen("screen-onboarding"); }
      else { await enterGame(); }
    }
  }
})();
