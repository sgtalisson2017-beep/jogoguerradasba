<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1" />
<title>Guerra das Nações</title>
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<style>
  :root{
    --bg:#0b1220; --bg2:#111a2e; --panel:#16213a; --panel2:#1c2a47;
    --border:#2a3a5c; --text:#e7ecf7; --muted:#8fa0c2; --accent:#f2b705;
    --accent2:#22c55e; --danger:#ef4444; --blue:#3b82f6;
    --radius:12px;
    font-family: 'Segoe UI', Roboto, system-ui, -apple-system, sans-serif;
  }
  *{box-sizing:border-box;}
  html,body{margin:0;padding:0;background:var(--bg);color:var(--text);min-height:100vh;}
  body{padding-bottom:70px;}
  .hidden{display:none !important;}
  button{cursor:pointer;font-family:inherit;}
  input, select, button{font-size:15px;}
  ::-webkit-scrollbar{width:8px;height:8px;}
  ::-webkit-scrollbar-thumb{background:var(--border);border-radius:8px;}

  /* ---------- Layout genérico ---------- */
  .center-screen{min-height:100vh;display:flex;align-items:center;justify-content:center;padding:20px;}
  .card{background:var(--panel);border:1px solid var(--border);border-radius:var(--radius);padding:24px;width:100%;max-width:420px;}
  .card h1{margin:0 0 6px;font-size:24px;}
  .card p.sub{color:var(--muted);margin:0 0 20px;font-size:14px;}
  label{display:block;font-size:13px;color:var(--muted);margin:14px 0 6px;}
  input[type=text], input[type=password], input[type=number], select{
    width:100%;padding:10px 12px;border-radius:8px;border:1px solid var(--border);
    background:var(--bg2);color:var(--text);
  }
  input[type=color]{width:52px;height:36px;border:1px solid var(--border);border-radius:8px;background:var(--bg2);padding:2px;}
  .btn{
    display:inline-flex;align-items:center;justify-content:center;gap:8px;
    padding:11px 18px;border-radius:8px;border:none;font-weight:600;
    background:var(--accent);color:#1a1204;
  }
  .btn.secondary{background:var(--panel2);color:var(--text);border:1px solid var(--border);}
  .btn.danger{background:var(--danger);color:#fff;}
  .btn.block{width:100%;margin-top:18px;}
  .btn:disabled{opacity:.45;cursor:not-allowed;}
  .error-msg{color:var(--danger);font-size:13px;margin-top:10px;min-height:16px;}
  .grid2{display:grid;grid-template-columns:1fr 1fr;gap:12px;}

  /* ---------- Login ---------- */
  .user-pick{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:6px;}
  .user-pick button{padding:14px 8px;border-radius:10px;border:1px solid var(--border);background:var(--bg2);color:var(--text);font-weight:600;text-transform:capitalize;}
  .user-pick button.active{border-color:var(--accent);background:#2a2210;color:var(--accent);}

  /* ---------- Top bar do jogo ---------- */
  .topbar{
    position:sticky;top:0;z-index:20;display:flex;align-items:center;gap:12px;
    padding:10px 14px;background:var(--panel);border-bottom:1px solid var(--border);
  }
  .topbar .flag{width:36px;height:36px;border-radius:6px;object-fit:cover;border:2px solid var(--border);background:var(--bg2);}
  .topbar .name{font-weight:700;}
  .topbar .owner{color:var(--muted);font-size:12px;}
  .resbar{display:flex;gap:10px;margin-left:auto;flex-wrap:wrap;justify-content:flex-end;}
  .respill{background:var(--bg2);border:1px solid var(--border);border-radius:20px;padding:6px 12px;font-size:13px;display:flex;gap:6px;align-items:center;white-space:nowrap;}
  .logout-btn{background:transparent;border:1px solid var(--border);color:var(--muted);border-radius:8px;padding:8px 10px;}

  main{max-width:1000px;margin:0 auto;padding:16px;}
  .section-title{font-size:18px;font-weight:700;margin:4px 0 12px;display:flex;align-items:center;gap:8px;}
  .panel{background:var(--panel);border:1px solid var(--border);border-radius:var(--radius);padding:16px;margin-bottom:16px;}
  .stat-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(120px,1fr));gap:10px;margin-bottom:14px;}
  .stat{background:var(--bg2);border:1px solid var(--border);border-radius:10px;padding:10px 12px;}
  .stat .lbl{color:var(--muted);font-size:11px;text-transform:uppercase;letter-spacing:.05em;}
  .stat .val{font-size:18px;font-weight:700;margin-top:2px;}

  /* ---------- Bottom nav ---------- */
  .bottomnav{
    position:fixed;bottom:0;left:0;right:0;display:flex;background:var(--panel);
    border-top:1px solid var(--border);z-index:30;
  }
  .bottomnav button{
    flex:1;background:transparent;border:none;color:var(--muted);padding:10px 4px;
    display:flex;flex-direction:column;align-items:center;gap:2px;font-size:11px;
  }
  .bottomnav button.active{color:var(--accent);}
  .bottomnav .ic{font-size:19px;}

  /* ---------- Território / grid de construção ---------- */
  .territory-wrap{overflow:auto;border:1px solid var(--border);border-radius:10px;background:var(--bg2);padding:10px;}
  .tgrid{display:grid;gap:4px;width:max-content;margin:0 auto;}
  .tcell{
    width:38px;height:38px;border-radius:6px;background:#0e1727;border:1px solid var(--border);
    display:flex;align-items:center;justify-content:center;font-size:18px;position:relative;
  }
  .tcell.empty{cursor:pointer;}
  .tcell.empty:hover{background:#152036;border-color:var(--accent);}
  .build-legend{display:flex;flex-wrap:wrap;gap:10px;margin-top:12px;font-size:12px;color:var(--muted);}
  .build-legend span{display:flex;align-items:center;gap:4px;}

  .build-list{display:grid;grid-template-columns:repeat(auto-fill,minmax(150px,1fr));gap:10px;margin-top:14px;}
  .build-card{background:var(--bg2);border:1px solid var(--border);border-radius:10px;padding:12px;text-align:center;}
  .build-card .icon{font-size:26px;}
  .build-card .name{font-weight:700;margin:4px 0 2px;font-size:13px;}
  .build-card .desc{font-size:11px;color:var(--muted);min-height:32px;}
  .build-card .cost{font-size:12px;margin:6px 0;color:var(--accent);}
  .build-card button{width:100%;margin-top:4px;padding:7px;font-size:12px;}

  /* ---------- Exército ---------- */
  .unit-row{display:flex;align-items:center;gap:12px;background:var(--bg2);border:1px solid var(--border);border-radius:10px;padding:12px;margin-bottom:10px;}
  .unit-row .icon{font-size:26px;width:36px;text-align:center;}
  .unit-row .info{flex:1;}
  .unit-row .info .n{font-weight:700;}
  .unit-row .info .m{font-size:12px;color:var(--muted);}
  .unit-row input[type=number]{width:70px;}
  .train-bar{height:8px;border-radius:8px;background:var(--bg);border:1px solid var(--border);overflow:hidden;margin-top:8px;}
  .train-bar .fill{height:100%;background:linear-gradient(90deg,var(--accent),var(--accent2));}

  /* ---------- Mundo ---------- */
  .world-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(230px,1fr));gap:14px;}
  .world-card{background:var(--bg2);border:1px solid var(--border);border-radius:12px;padding:14px;}
  .world-card .head{display:flex;align-items:center;gap:10px;}
  .world-card .head img, .world-card .head .noflag{width:44px;height:44px;border-radius:8px;object-fit:cover;background:#0e1727;border:1px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:20px;}
  .world-card .head .cname{font-weight:700;}
  .world-card .head .uname{font-size:12px;color:var(--muted);text-transform:capitalize;}
  .world-card .power{margin:10px 0;font-size:13px;color:var(--muted);}
  .world-card .power b{color:var(--accent);}
  .world-card.me{border-color:var(--accent);}

  /* ---------- Batalhas ---------- */
  .battle-row{background:var(--bg2);border:1px solid var(--border);border-radius:10px;padding:12px;margin-bottom:8px;font-size:13px;}
  .battle-row .top{display:flex;justify-content:space-between;font-weight:700;margin-bottom:4px;}
  .battle-row .win{color:var(--accent2);}
  .battle-row .lose{color:var(--danger);}
  .battle-row .meta{color:var(--muted);font-size:11px;}

  /* ---------- Modal ---------- */
  .modal-bg{position:fixed;inset:0;background:rgba(0,0,0,.6);display:flex;align-items:center;justify-content:center;z-index:100;padding:16px;}
  .modal{background:var(--panel);border:1px solid var(--border);border-radius:14px;padding:20px;max-width:440px;width:100%;max-height:88vh;overflow:auto;}
  .modal h3{margin:0 0 12px;}
  .modal .close-x{float:right;background:none;border:none;color:var(--muted);font-size:20px;}

  @media(min-width:760px){
    .bottomnav{
      position:sticky;top:57px;left:0;right:0;flex-direction:row;justify-content:center;gap:6px;
      background:transparent;border:none;padding:10px 0 0;
    }
    .bottomnav button{flex:none;flex-direction:row;padding:9px 16px;border-radius:20px;background:var(--panel);border:1px solid var(--border);}
    .bottomnav button.active{background:#2a2210;border-color:var(--accent);}
    body{padding-bottom:20px;}
  }
</style>
</head>
<body>

<!-- ============== LOGIN ============== -->
<div id="screen-login" class="center-screen">
  <div class="card">
    <h1>🌍 Guerra das Nações</h1>
    <p class="sub">Escolha seu jogador e entre com a senha.</p>
    <label>Jogador</label>
    <div class="user-pick" id="userPick"></div>
    <label>Senha</label>
    <input type="password" id="loginPassword" placeholder="••••" />
    <button class="btn block" id="loginBtn">Entrar</button>
    <div class="error-msg" id="loginError"></div>
  </div>
</div>

<!-- ============== ONBOARDING ============== -->
<div id="screen-onboarding" class="center-screen hidden">
  <div class="card" style="max-width:480px;">
    <h1>🏳️ Funde seu país</h1>
    <p class="sub">É a sua primeira vez jogando — configure sua nação.</p>

    <label>Nome do país</label>
    <input type="text" id="ob-name" maxlength="24" placeholder="Ex: Nova Roma" />

    <div class="grid2">
      <div>
        <label>Cor principal</label>
        <input type="color" id="ob-color1" value="#2563eb" />
      </div>
      <div>
        <label>Cor secundária</label>
        <input type="color" id="ob-color2" value="#0f172a" />
      </div>
    </div>

    <label>Bandeira (imagem, opcional)</label>
    <input type="file" id="ob-flag" accept="image/*" />
    <div id="ob-flag-preview" style="margin-top:8px;"></div>

    <label>Tamanho do território</label>
    <select id="ob-size">
      <option value="pequeno">Pequeno (6x6) — produção normal</option>
      <option value="medio">Médio (8x8) — produção +20%</option>
      <option value="grande">Grande (10x10) — produção +50%</option>
    </select>

    <label>População inicial</label>
    <select id="ob-pop">
      <option value="1000">1.000 habitantes</option>
      <option value="5000">5.000 habitantes</option>
      <option value="10000">10.000 habitantes</option>
    </select>

    <label>Fonte de riqueza (recurso produzido)</label>
    <select id="ob-resource">
      <option value="madeira">🪵 Madeira</option>
      <option value="ferro">⛏️ Ferro</option>
    </select>

    <button class="btn block" id="ob-submit">Fundar nação</button>
    <div class="error-msg" id="ob-error"></div>
  </div>
</div>

<!-- ============== JOGO ============== -->
<div id="screen-game" class="hidden">
  <div class="topbar">
    <img id="gg-flag" class="flag" src="" />
    <div>
      <div class="name" id="gg-name">—</div>
      <div class="owner" id="gg-owner">—</div>
    </div>
    <div class="resbar">
      <div class="respill">🪵 <span id="res-wood">0</span></div>
      <div class="respill">⛏️ <span id="res-iron">0</span></div>
      <div class="respill">👥 <span id="res-pop">0</span></div>
      <div class="respill">🎖️ Treino <span id="res-train">0</span>/10</div>
    </div>
    <button class="logout-btn" id="logoutBtn">Sair</button>
  </div>

  <div class="bottomnav">
    <button data-tab="territorio" class="active"><span class="ic">🗺️</span>Território</button>
    <button data-tab="exercito"><span class="ic">⚔️</span>Exército</button>
    <button data-tab="mundo"><span class="ic">🌍</span>Mundo</button>
    <button data-tab="batalhas"><span class="ic">📜</span>Batalhas</button>
  </div>

  <main>
    <!-- TAB: TERRITÓRIO -->
    <section id="tab-territorio">
      <div class="section-title">🗺️ Meu Território</div>
      <div class="panel">
        <p style="color:var(--muted);font-size:13px;margin-top:0;">Clique em uma célula vazia para construir. Construa uma Prefeitura primeiro.</p>
        <div class="territory-wrap"><div class="tgrid" id="tgrid"></div></div>
        <div class="build-legend">
          <span>🏛️ Prefeitura</span><span>⚔️ Quartel</span><span>✈️ Pista de Aviação</span><span>🏢 Prédio</span>
        </div>
      </div>
    </section>

    <!-- TAB: EXÉRCITO -->
    <section id="tab-exercito" class="hidden">
      <div class="section-title">⚔️ Meu Exército</div>
      <div class="panel">
        <p style="color:var(--muted);font-size:13px;margin-top:0;">
          O nível de treinamento sobe automaticamente com o tempo (máx. 10, +1 a cada minuto) e fortalece todo o seu exército.
        </p>
        <div class="train-bar"><div class="fill" id="trainFill" style="width:0%"></div></div>
        <div id="armyList" style="margin-top:16px;"></div>
      </div>
    </section>

    <!-- TAB: MUNDO -->
    <section id="tab-mundo" class="hidden">
      <div class="section-title">🌍 Nações do Mundo</div>
      <div class="world-grid" id="worldGrid"></div>
    </section>

    <!-- TAB: BATALHAS -->
    <section id="tab-batalhas" class="hidden">
      <div class="section-title">📜 Histórico de Batalhas</div>
      <div id="battleLog"></div>
    </section>
  </main>
</div>

<div id="modalRoot"></div>

<script>
/* ============================================================
   CONFIGURAÇÃO DO SUPABASE
   1. Crie um projeto grátis em https://supabase.com
   2. Rode o arquivo schema.sql no SQL Editor do projeto
   3. Cole abaixo a Project URL e a chave "anon public"
      (Settings -> API)
   ============================================================ */
const SUPABASE_URL = "https://eevoeynygkuypzhelhhw.supabase.co";
const SUPABASE_ANON_KEY = "sb_publishable_02qDoqSGfxT2BoNcpN9_6w_Y_Bg0qfo";

const sb = (SUPABASE_URL.startsWith("http"))
  ? supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY)
  : null;

/* ============================================================
   CONFIGURAÇÕES DO JOGO (ajuste os números aqui se quiser)
   ============================================================ */
const USERS = ["alisson", "amanda", "thiago", "natalia"];
const SHARED_PASSWORD = "1234";
const RESOURCE_PER_MINUTE = 100;
const TERRITORY_CONFIG = {
  pequeno: { grid: 6,  prodMult: 1.0, label: "Pequeno (6x6)" },
  medio:   { grid: 8,  prodMult: 1.2, label: "Médio (8x8)" },
  grande:  { grid: 10, prodMult: 1.5, label: "Grande (10x10)" },
};
const BUILDING_INFO = {
  prefeitura: { label: "Prefeitura",       icon: "🏛️", cost: 100, max: 1,  desc: "+10% de produção. Construa primeiro." },
  quartel:    { label: "Quartel",          icon: "⚔️", cost: 50,  max: 5,  desc: "Necessário para treinar soldados." },
  pista:      { label: "Pista de Aviação", icon: "✈️", cost: 80,  max: 3,  desc: "Necessária para produzir aviões." },
  predio:     { label: "Prédio",           icon: "🏢", cost: 40,  max: 10, desc: "+100 de população máxima." },
};
const UNIT_INFO = {
  soldiers: { label: "Soldados", icon: "🪖", cost: 10, power: 1, needs: "quartel" },
  tanks:    { label: "Tanques",  icon: "🛡️", cost: 20, power: 3, needs: "prefeitura" },
  planes:   { label: "Aviões",   icon: "✈️", cost: 20, power: 4, needs: "pista" },
};

/* ============================================================
   ESTADO
   ============================================================ */
let state = {
  username: null,
  me: null,          // linha da tabela players
  myBuildings: [],
  allPlayers: [],
  allBattles: [],
  activeTab: "territorio",
};

const $ = (sel) => document.querySelector(sel);
const $$ = (sel) => Array.from(document.querySelectorAll(sel));

function showScreen(id){
  ["screen-login","screen-onboarding","screen-game"].forEach(s=>{
    $("#"+s).classList.toggle("hidden", s!==id);
  });
}

/* ============================================================
   LOGIN
   ============================================================ */
let selectedUser = null;

function renderUserPick(){
  const wrap = $("#userPick");
  wrap.innerHTML = "";
  USERS.forEach(u=>{
    const b = document.createElement("button");
    b.textContent = u;
    b.onclick = ()=>{
      selectedUser = u;
      $$("#userPick button").forEach(x=>x.classList.remove("active"));
      b.classList.add("active");
    };
    wrap.appendChild(b);
  });
}

async function doLogin(){
  const err = $("#loginError");
  err.textContent = "";
  if (!sb){ err.textContent = "Configure o Supabase no topo do arquivo index.html antes de jogar."; return; }
  if (!selectedUser){ err.textContent = "Escolha um jogador."; return; }
  const pass = $("#loginPassword").value;
  if (pass !== SHARED_PASSWORD){ err.textContent = "Senha incorreta."; return; }

  const { data, error } = await sb.from("players").select("*").eq("username", selectedUser).maybeSingle();
  if (error){ err.textContent = "Erro ao conectar no Supabase: " + error.message; return; }
  if (!data){ err.textContent = "Usuário não encontrado. Rode o schema.sql no Supabase."; return; }

  state.username = selectedUser;
  state.me = data;
  localStorage.setItem("guerra_username", selectedUser);

  if (!data.onboarded){
    showScreen("screen-onboarding");
  } else {
    await enterGame();
  }
}

/* ============================================================
   ONBOARDING
   ============================================================ */
let flagDataUrl = null;

$("#ob-flag") && ($("#ob-flag").onchange = (e)=>{
  const file = e.target.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = (ev)=>{
    const img = new Image();
    img.onload = ()=>{
      // redimensiona pra manter o base64 leve
      const canvas = document.createElement("canvas");
      const size = 128;
      canvas.width = size; canvas.height = size;
      const ctx = canvas.getContext("2d");
      ctx.drawImage(img, 0, 0, size, size);
      flagDataUrl = canvas.toDataURL("image/png");
      $("#ob-flag-preview").innerHTML = `<img src="${flagDataUrl}" style="width:64px;height:64px;border-radius:8px;border:1px solid var(--border);">`;
    };
    img.src = ev.target.result;
  };
  reader.readAsDataURL(file);
});

async function submitOnboarding(){
  const err = $("#ob-error");
  err.textContent = "";
  const name = $("#ob-name").value.trim();
  if (!name){ err.textContent = "Dê um nome para o seu país."; return; }

  const size = $("#ob-size").value;
  const pop = parseInt($("#ob-pop").value, 10);
  const resourceType = $("#ob-resource").value;

  const payload = {
    country_name: name,
    color_primary: $("#ob-color1").value,
    color_secondary: $("#ob-color2").value,
    flag_data: flagDataUrl,
    territory_size: size,
    population: pop,
    max_population: pop,
    resource_type: resourceType,
    onboarded: true,
    training_started_at: new Date().toISOString(),
    last_tick: new Date().toISOString(),
  };

  const { data, error } = await sb.from("players").update(payload).eq("username", state.username).select().single();
  if (error){ err.textContent = "Erro ao salvar: " + error.message; return; }
  state.me = data;
  await enterGame();
}

/* ============================================================
   ENTRAR NO JOGO / CARREGAR DADOS
   ============================================================ */
async function enterGame(){
  showScreen("screen-game");
  await refreshAll();
  subscribeRealtime();
  setInterval(tickResources, 1000);
  setInterval(syncResources, 20000);
  setActiveTab(state.activeTab);
}

async function refreshAll(){
  const [{ data: me }, { data: players }, { data: buildings }, { data: battles }] = await Promise.all([
    sb.from("players").select("*").eq("username", state.username).single(),
    sb.from("players").select("*").eq("onboarded", true),
    sb.from("buildings").select("*"),
    sb.from("battles").select("*").order("created_at", { ascending: false }).limit(30),
  ]);
  state.me = me;
  state.allPlayers = players || [];
  state.myBuildings = (buildings || []).filter(b=>b.player_id === me.id);
  state.allBuildingsAll = buildings || [];
  state.allBattles = battles || [];
  renderTopbar();
  renderTerritory();
  renderArmy();
  renderWorld();
  renderBattles();
}

function subscribeRealtime(){
  sb.channel("public:all")
    .on("postgres_changes", { event:"*", schema:"public", table:"players" }, ()=>refreshAll())
    .on("postgres_changes", { event:"*", schema:"public", table:"buildings" }, ()=>refreshAll())
    .on("postgres_changes", { event:"*", schema:"public", table:"battles" }, ()=>refreshAll())
    .subscribe();
}

/* ============================================================
   PRODUÇÃO DE RECURSOS (tick local + sync no banco)
   ============================================================ */
function currentTrainingLevel(p){
  const started = new Date(p.training_started_at).getTime();
  const mins = (Date.now() - started) / 60000;
  return Math.max(0, Math.min(10, Math.floor(mins)));
}

function prodRatePerMinute(p){
  const cfg = TERRITORY_CONFIG[p.territory_size] || TERRITORY_CONFIG.pequeno;
  const hasPrefeitura = (state.allBuildingsAll||[]).some(b=>b.player_id===p.id && b.type==="prefeitura");
  let mult = cfg.prodMult * (hasPrefeitura ? 1.1 : 1.0);
  return RESOURCE_PER_MINUTE * mult;
}

function estimateCurrentResource(p){
  const rate = prodRatePerMinute(p);
  const elapsedMin = (Date.now() - new Date(p.last_tick).getTime()) / 60000;
  const gained = Math.max(0, elapsedMin) * rate;
  const field = p.resource_type === "ferro" ? "iron" : "wood";
  return { field, value: (p[field]||0) + gained };
}

function tickResources(){
  if (!state.me) return;
  const { field, value } = estimateCurrentResource(state.me);
  $("#res-wood").textContent = field==="wood" ? Math.floor(value) : Math.floor(state.me.wood||0);
  $("#res-iron").textContent = field==="iron" ? Math.floor(value) : Math.floor(state.me.iron||0);
  $("#res-pop").textContent = state.me.population;
  const lvl = currentTrainingLevel(state.me);
  $("#res-train").textContent = lvl;
  $("#trainFill") && ($("#trainFill").style.width = (lvl*10)+"%");
}

async function syncResources(){
  if (!state.me) return;
  const { field, value } = estimateCurrentResource(state.me);
  const update = { last_tick: new Date().toISOString() };
  update[field] = value;
  const { data, error } = await sb.from("players").update(update).eq("id", state.me.id).select().single();
  if (!error && data) state.me = data;
}

/* ============================================================
   TOPBAR
   ============================================================ */
function renderTopbar(){
  const p = state.me;
  $("#gg-name").textContent = p.country_name || "—";
  $("#gg-owner").textContent = state.username;
  $("#gg-flag").src = p.flag_data || svgPlaceholderFlag(p.color_primary, p.color_secondary);
  tickResources();
}

function svgPlaceholderFlag(c1, c2){
  const svg = `<svg xmlns='http://www.w3.org/2000/svg' width='64' height='64'>
    <rect width='64' height='32' fill='${c1||"#2563eb"}'/>
    <rect y='32' width='64' height='32' fill='${c2||"#0f172a"}'/>
  </svg>`;
  return "data:image/svg+xml;base64," + btoa(svg);
}

/* ============================================================
   ABAS
   ============================================================ */
function setActiveTab(tab){
  state.activeTab = tab;
  ["territorio","exercito","mundo","batalhas"].forEach(t=>{
    $("#tab-"+t).classList.toggle("hidden", t!==tab);
  });
  $$(".bottomnav button").forEach(b=>b.classList.toggle("active", b.dataset.tab===tab));
}
$$(".bottomnav button").forEach(b=>b.onclick = ()=>setActiveTab(b.dataset.tab));

/* ============================================================
   TERRITÓRIO / CONSTRUÇÕES
   ============================================================ */
function renderTerritory(){
  const p = state.me;
  const cfg = TERRITORY_CONFIG[p.territory_size] || TERRITORY_CONFIG.pequeno;
  const grid = $("#tgrid");
  grid.style.gridTemplateColumns = `repeat(${cfg.grid}, 38px)`;
  grid.innerHTML = "";

  const byPos = {};
  state.myBuildings.forEach(b=> byPos[b.x+","+b.y] = b);

  for (let y=0; y<cfg.grid; y++){
    for (let x=0; x<cfg.grid; x++){
      const b = byPos[x+","+y];
      const cell = document.createElement("div");
      cell.className = "tcell" + (b ? "" : " empty");
      if (b){
        cell.textContent = BUILDING_INFO[b.type].icon;
        cell.title = BUILDING_INFO[b.type].label;
      } else {
        cell.onclick = ()=> openBuildModal(x,y);
      }
      grid.appendChild(cell);
    }
  }
}

function openBuildModal(x,y){
  const p = state.me;
  const field = p.resource_type === "ferro" ? "iron" : "wood";
  const resLabel = p.resource_type === "ferro" ? "⛏️ Ferro" : "🪵 Madeira";

  let cardsHtml = "";
  Object.entries(BUILDING_INFO).forEach(([key, info])=>{
    const count = state.myBuildings.filter(b=>b.type===key).length;
    const maxed = count >= info.max;
    const canAfford = (p[field]||0) >= info.cost;
    cardsHtml += `
      <div class="build-card">
        <div class="icon">${info.icon}</div>
        <div class="name">${info.label}</div>
        <div class="desc">${info.desc}</div>
        <div class="cost">${info.cost} ${resLabel} · ${count}/${info.max}</div>
        <button class="btn secondary" ${maxed||!canAfford?"disabled":""} data-build="${key}">
          ${maxed ? "Máximo atingido" : (canAfford ? "Construir" : "Sem recursos")}
        </button>
      </div>`;
  });

  openModal(`
    <button class="close-x" onclick="closeModal()">✕</button>
    <h3>Construir em (${x+1}, ${y+1})</h3>
    <div class="build-list">${cardsHtml}</div>
  `);

  $$("#modalRoot [data-build]").forEach(btn=>{
    btn.onclick = ()=> buildAt(x, y, btn.dataset.build);
  });
}

async function buildAt(x, y, type){
  const p = state.me;
  const info = BUILDING_INFO[type];
  const field = p.resource_type === "ferro" ? "iron" : "wood";
  const { value: currentVal } = estimateCurrentResource(p);
  if (currentVal < info.cost){ alert("Recursos insuficientes."); return; }

  const newVal = currentVal - info.cost;
  const update = { last_tick: new Date().toISOString() };
  update[field] = newVal;
  const { data: updated, error: e1 } = await sb.from("players").update(update).eq("id", p.id).select().single();
  if (e1){ alert(e1.message); return; }

  const { error: e2 } = await sb.from("buildings").insert({ player_id: p.id, type, x, y });
  if (e2){ alert(e2.message); return; }

  state.me = updated;
  closeModal();
  await refreshAll();
}

/* ============================================================
   EXÉRCITO
   ============================================================ */
function maxArmyCap(p){
  return Math.floor((p.max_population||0) / 20);
}
function totalArmy(p){
  return (p.soldiers||0) + (p.tanks||0) + (p.planes||0);
}

function renderArmy(){
  const p = state.me;
  const field = p.resource_type === "ferro" ? "iron" : "wood";
  const resLabel = p.resource_type === "ferro" ? "⛏️ Ferro" : "🪵 Madeira";
  const lvl = currentTrainingLevel(p);
  $("#trainFill").style.width = (lvl*10)+"%";

  const list = $("#armyList");
  list.innerHTML = "";
  const cap = maxArmyCap(p);
  const used = totalArmy(p);

  const capNote = document.createElement("p");
  capNote.style.cssText = "color:var(--muted);font-size:12px;margin-top:0;";
  capNote.textContent = `Capacidade do exército: ${used}/${cap} (baseada na população máxima)`;
  list.appendChild(capNote);

  Object.entries(UNIT_INFO).forEach(([key, info])=>{
    const owned = p[key] || 0;
    const hasBuilding = state.myBuildings.some(b=>b.type===info.needs);
    const row = document.createElement("div");
    row.className = "unit-row";
    row.innerHTML = `
      <div class="icon">${info.icon}</div>
      <div class="info">
        <div class="n">${info.label}: ${owned}</div>
        <div class="m">Custo: ${info.cost} ${resLabel} cada · Poder: ${info.power} · Requer ${BUILDING_INFO[info.needs].label}</div>
      </div>
      <input type="number" min="1" value="1" style="width:60px" id="qty-${key}">
      <button class="btn secondary" data-unit="${key}" ${hasBuilding?"":"disabled"}>${hasBuilding?"Recrutar":"Bloqueado"}</button>
    `;
    list.appendChild(row);
  });

  $$("#armyList [data-unit]").forEach(btn=>{
    btn.onclick = ()=> recruitUnit(btn.dataset.unit);
  });
}

async function recruitUnit(unitKey){
  const p = state.me;
  const info = UNIT_INFO[unitKey];
  const field = p.resource_type === "ferro" ? "iron" : "wood";
  const qty = Math.max(1, parseInt($("#qty-"+unitKey).value || "1", 10));
  const totalCost = info.cost * qty;

  const cap = maxArmyCap(p);
  if (totalArmy(p) + qty > cap){ alert("Você atingiu a capacidade máxima do exército. Construa mais Prédios para aumentar a população."); return; }

  const { value: currentVal } = estimateCurrentResource(p);
  if (currentVal < totalCost){ alert("Recursos insuficientes."); return; }

  const update = { last_tick: new Date().toISOString() };
  update[field] = currentVal - totalCost;
  update[unitKey] = (p[unitKey]||0) + qty;

  const { data, error } = await sb.from("players").update(update).eq("id", p.id).select().single();
  if (error){ alert(error.message); return; }
  state.me = data;
  await refreshAll();
}

/* ============================================================
   MUNDO / ATAQUES
   ============================================================ */
function playerPower(p){
  const lvl = currentTrainingLevel(p);
  const mult = 1 + lvl*0.1;
  const base = (p.soldiers||0)*UNIT_INFO.soldiers.power + (p.tanks||0)*UNIT_INFO.tanks.power + (p.planes||0)*UNIT_INFO.planes.power;
  return Math.round(base * mult);
}

function renderWorld(){
  const grid = $("#worldGrid");
  grid.innerHTML = "";
  state.allPlayers.forEach(p=>{
    const isMe = p.username === state.username;
    const card = document.createElement("div");
    card.className = "world-card" + (isMe ? " me" : "");
    const flagHtml = p.flag_data
      ? `<img src="${p.flag_data}">`
      : `<div class="noflag">🏳️</div>`;
    card.innerHTML = `
      <div class="head">
        ${flagHtml}
        <div>
          <div class="cname">${p.country_name || "(sem nome)"}</div>
          <div class="uname">${p.username}${isMe?" · você":""}</div>
        </div>
      </div>
      <div class="power">Poder estimado: <b>${playerPower(p)}</b> · Treino ${currentTrainingLevel(p)}/10</div>
      ${isMe ? "" : `<button class="btn danger block" data-attack="${p.id}">⚔️ Atacar</button>`}
    `;
    grid.appendChild(card);
  });

  $$("#worldGrid [data-attack]").forEach(btn=>{
    btn.onclick = ()=> openAttackModal(btn.dataset.attack);
  });
}

function openAttackModal(defenderId){
  const defender = state.allPlayers.find(p=>p.id===defenderId);
  const me = state.me;
  if (totalArmy(me) === 0){ alert("Você não tem tropas para atacar. Recrute soldados, tanques ou aviões primeiro."); return; }

  let rows = "";
  Object.entries(UNIT_INFO).forEach(([key, info])=>{
    const owned = me[key] || 0;
    rows += `
      <div class="unit-row">
        <div class="icon">${info.icon}</div>
        <div class="info"><div class="n">${info.label} (você tem ${owned})</div></div>
        <input type="number" min="0" max="${owned}" value="0" style="width:70px" id="atk-${key}">
      </div>`;
  });

  openModal(`
    <button class="close-x" onclick="closeModal()">✕</button>
    <h3>Atacar ${defender.country_name}</h3>
    <p style="color:var(--muted);font-size:13px;">Escolha quais tropas enviar no ataque. O defensor luta com todo o exército dele.</p>
    ${rows}
    <button class="btn danger block" id="confirmAttack">Lançar ataque</button>
    <div class="error-msg" id="attackError"></div>
  `);

  $("#confirmAttack").onclick = ()=> resolveAttack(defender);
}

async function resolveAttack(defender){
  const me = state.me;
  const committed = {};
  let any = false;
  Object.keys(UNIT_INFO).forEach(key=>{
    const v = Math.max(0, Math.min(me[key]||0, parseInt($("#atk-"+key).value || "0", 10)));
    committed[key] = v;
    if (v>0) any = true;
  });
  if (!any){ $("#attackError").textContent = "Selecione ao menos uma tropa."; return; }

  const meTrainMult = 1 + currentTrainingLevel(me)*0.1;
  const defTrainMult = 1 + currentTrainingLevel(defender)*0.1;

  const attackerPower = Math.round((committed.soldiers*UNIT_INFO.soldiers.power + committed.tanks*UNIT_INFO.tanks.power + committed.planes*UNIT_INFO.planes.power) * meTrainMult);
  const defenderPower = Math.round(((defender.soldiers||0)*UNIT_INFO.soldiers.power + (defender.tanks||0)*UNIT_INFO.tanks.power + (defender.planes||0)*UNIT_INFO.planes.power) * defTrainMult);

  const total = attackerPower + defenderPower || 1;
  const ratio = attackerPower / total; // >0.5 favorece atacante
  const attackerWins = ratio >= 0.5;

  const loserLossFrac = Math.min(0.7, Math.max(0.3, 0.3 + 0.4*Math.abs(ratio-0.5)*2));
  const winnerLossFrac = Math.min(0.25, Math.max(0.10, 0.25 - 0.15*Math.abs(ratio-0.5)*2));

  const attackerLossFrac = attackerWins ? winnerLossFrac : loserLossFrac;
  const defenderLossFrac = attackerWins ? loserLossFrac : winnerLossFrac;

  const lossesAttacker = {}, lossesDefender = {};
  Object.keys(UNIT_INFO).forEach(key=>{
    lossesAttacker[key] = Math.floor(committed[key] * attackerLossFrac);
    lossesDefender[key] = Math.floor((defender[key]||0) * defenderLossFrac);
  });

  const meUpdate = {};
  Object.keys(UNIT_INFO).forEach(key=>{
    meUpdate[key] = Math.max(0, (me[key]||0) - lossesAttacker[key]);
  });
  const defUpdate = {};
  Object.keys(UNIT_INFO).forEach(key=>{
    defUpdate[key] = Math.max(0, (defender[key]||0) - lossesDefender[key]);
  });

  await sb.from("players").update(meUpdate).eq("id", me.id);
  await sb.from("players").update(defUpdate).eq("id", defender.id);
  await sb.from("battles").insert({
    attacker_id: me.id, defender_id: defender.id,
    attacker_username: me.username, defender_username: defender.username,
    attacker_power: attackerPower, defender_power: defenderPower,
    result: attackerWins ? "attacker" : "defender",
    committed, losses_attacker: lossesAttacker, losses_defender: lossesDefender,
  });

  closeModal();
  openModal(`
    <button class="close-x" onclick="closeModal()">✕</button>
    <h3>${attackerWins ? "🏆 Vitória!" : "💥 Derrota"}</h3>
    <p>Seu poder: <b>${attackerPower}</b> · Poder de ${defender.country_name}: <b>${defenderPower}</b></p>
    <p style="color:var(--muted);font-size:13px;">Suas perdas: 🪖${lossesAttacker.soldiers} 🛡️${lossesAttacker.tanks} ✈️${lossesAttacker.planes}<br>
    Perdas do inimigo: 🪖${lossesDefender.soldiers} 🛡️${lossesDefender.tanks} ✈️${lossesDefender.planes}</p>
    <button class="btn block" onclick="closeModal()">Fechar</button>
  `);
  await refreshAll();
}

/* ============================================================
   BATALHAS (log)
   ============================================================ */
function renderBattles(){
  const wrap = $("#battleLog");
  wrap.innerHTML = "";
  if (!state.allBattles.length){
    wrap.innerHTML = `<p style="color:var(--muted);">Nenhuma batalha ainda.</p>`;
    return;
  }
  state.allBattles.forEach(b=>{
    const winnerName = b.result === "attacker" ? b.attacker_username : b.defender_username;
    const row = document.createElement("div");
    row.className = "battle-row";
    row.innerHTML = `
      <div class="top"><span>${b.attacker_username} ⚔️ ${b.defender_username}</span><span class="win">${winnerName} venceu</span></div>
      <div class="meta">Poder: ${b.attacker_power} vs ${b.defender_power} · ${new Date(b.created_at).toLocaleString("pt-BR")}</div>
    `;
    wrap.appendChild(row);
  });
}

